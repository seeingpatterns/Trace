# Cinegraph 환경변수 — 실제 값은 .env에 넣으세요!
# 이 파일은 git에 커밋되어도 안전합니다.

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# 관리자 비밀번호 해시 (bcrypt)
# 생성: node -e "import('bcrypt').then(b => b.default.hash('your-password', 12).then(console.log))"
ADMIN_PASSWORD_HASH=$2b$12$your-bcrypt-hash-here
